# ExternalForce
# External force applied at a specific position.

float32 position_x  # Application point X [m]
float32 position_y  # Application point Y [m]
float32 position_z  # Application point Z [m]
float32 force_x  # Force X component [N]
float32 force_y  # Force Y component [N]
float32 force_z  # Force Z component [N]
